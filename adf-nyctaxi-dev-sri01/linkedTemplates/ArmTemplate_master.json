{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-nyctaxi-dev-sri01"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"MySql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'MySql'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stnyctaxisri01.dfs.core.windows.net/"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-nyc-taxi-sri01.vault.azure.net/"
		},
		"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-nyctaxi-dev-sri01.database.windows.net"
		},
		"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-watermark-dev"
		},
		"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"MySql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"MySql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "nyc_taxi_source"
		},
		"MySql_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-nyctaxi-dev-sri01_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"MySql_password": {
						"value": "[parameters('MySql_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_server')]"
					},
					"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_database')]"
					},
					"AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabasesourcewatermark_ls_properties_typeProperties_userName')]"
					},
					"MySql_properties_typeProperties_server": {
						"value": "[parameters('MySql_properties_typeProperties_server')]"
					},
					"MySql_properties_typeProperties_database": {
						"value": "[parameters('MySql_properties_typeProperties_database')]"
					},
					"MySql_properties_typeProperties_username": {
						"value": "[parameters('MySql_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}