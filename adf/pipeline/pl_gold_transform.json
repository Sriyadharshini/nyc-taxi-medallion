{
	"name": "pl_gold_transform",
	"properties": {
		"activities": [
			{
				"name": "Lookup_Gold_Watermark",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "SELECT last_watermark_value\nFROM transformation_watermark\nWHERE layer_name = 'gold'\nAND target_table_name = 'taxi_trips'",
							"type": "Expression"
						},
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "AzureSqlTableforwatermark_ds",
						"type": "DatasetReference"
					}
				}
			}
		],
		"parameters": {
			"gold_path": {
				"type": "string",
				"defaultValue": "abfss://gold@stnyctaxisri01.dfs.core.windows.net/nyc_taxi/"
			}
		},
		"annotations": []
	}
}